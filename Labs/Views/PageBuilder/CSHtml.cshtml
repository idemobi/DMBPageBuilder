                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Rendering logic becomes reusable 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Page-level dependencies can still be registered during body rendering 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:The final document remains centrally orchestrated 
                }
            }

            @using (Html.PB_P().Begin())
            {
                @:PageBuilder does not fight Razor. It gives Razor a stronger rendering discipline.
            }

            @* ── Recommended usage ── *@
