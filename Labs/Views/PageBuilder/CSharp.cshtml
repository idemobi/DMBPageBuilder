@using DMBBootstrapBuilder
@using DMBPageBuilder
@using DMBComponentBuilder
@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Using in C#", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Move rendering logic out of views when it becomes structural or reusable.
            }
        }
    }
}

@* ── Content ── *@
@using (Html.ContainerBuilder().SetPadding(SpacingSide.Y, SpacingSize.Five).Begin())
{
    @using (Html.RowBuilder().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).Begin())
        {

            @Html.TitleBuilder().SetTitle("Overview", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.PB_P().Begin())
            {
                @:PageBuilder can be used directly from C# code, not only from Razor views. This is useful when HTML generation must be encapsulated in reusable classes, framework code, services, or rendering infrastructure.
            }
            @using (Html.PB_P().Begin())
            {
                @:Using PageBuilder in C# makes it possible to centralize rendering behavior while preserving the same attribute system, style system, builder lifecycle, and page model used in Razor-based rendering.
            }

            @* ── Why render in C# ── *@
            @Html.TitleBuilder().SetTitle("Why render in C#", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.PB_P().Begin())
            {
                @:Rendering directly in C# is especially useful when:
            }

            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:A rendering pattern must be reused across many views 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:A component needs its own encapsulated logic 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Markup generation depends on application state or metadata 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:You are building framework-level components on top of PageBuilder 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:You are generating documentation or system pages automatically 
                }
            }

            @* ── Relationship with the pipeline ── *@
            @Html.TitleBuilder().SetTitle("Relationship with the rendering pipeline", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.PB_P().Begin())
            {
                @:Using builders in C# does not bypass the PageBuilder pipeline. Builders rendered in C# can still participate in the same page model as components rendered from Razor.
            }

            @using (Html.BlockBuilder().AsInfoCallout().Begin())
            {
                @using (Html.FlexBlockBuilder().Begin())
                {
                    @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                    {
                        @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                    }
                    @using (Html.BlockBuilder().Begin())
                    {
                        @Html.TitleBuilder().SetTitle("Same pipeline, different location", TitleLevel.Five).AsAlertHeading().Render()
                        @using (Html.PB_P().AsNoMargin().Begin())
                        {
                            @:A builder created in C# can still register scripts, stylesheets, and other page-level dependencies through
                            @using (Html.PB_Span().AsMonospace().Begin()) {
                    @:PageInformation 
                }
                            @: while it renders. The page pipeline remains the same — only the location of the rendering logic changes.
                        }
                    }
                }
            }

            @* ── Typical use cases ── *@
            @Html.TitleBuilder().SetTitle("Typical use cases", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Reusable HTML builders 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Layout infrastructure 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Custom rendering helpers 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Documentation pages 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Higher-level component libraries 
                }
            }

            @* ── Why this matters ── *@
            @Html.TitleBuilder().SetTitle("Why this matters", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.PB_P().Begin())
            {
                @:Once rendering logic moves into C#, it becomes easier to reuse, test, document, and evolve. This is one of the reasons PageBuilder works well as a foundation for larger rendering ecosystems. Instead of treating HTML generation as view-only logic, PageBuilder allows it to become part of the application architecture.
            }

            @* ── Recommended usage ── *@
            @Html.TitleBuilder().SetTitle("Recommended usage", TitleLevel.Two).AsSectionHeading().Render()

            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Use C# builders for repeated or framework-level rendering logic 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Keep them aligned with the shared page model 
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Let builders register their dependencies through
                    @using (Html.PB_Span().AsMonospace().Begin()) {
                    @:PageInformation 
                }
                    @: when needed
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin()) {
                    @:Keep the final page orchestration in the PageBuilder pipeline 
                }
            }

            @* ── Next Steps ── *@
            @using (Html.BlockBuilder().AsSidebarNote().Begin())
            {
                @using (Html.BlockBuilder().AsTextCenter().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Continue with Examples", TitleLevel.Four).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:See the rendering model applied to practical real-world scenarios.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("PageBuilder", "Examples").SetTitle("Examples →").SetIcon(IconStruct.Bootstrap("bi-arrow-right")).SetVariant(VariantStyle.Primary)).Render()
                }
            }

        }
    }
}
